# ─── canopy runtime artifacts ───────────────────────────────────────
# Graph database lives under .canopy/ — never committed
.canopy/
# canopy.yaml is the per-repo state file generated by `canopy init`. It
# contains LLM-generated descriptions and shouldn't be source-controlled.
canopy.yaml
*.sqlite
*.sqlite-journal
*.sqlite-wal
*.sqlite-shm
*.db
*.db-journal
*.db-wal
*.db-shm

# ─── Secrets / credentials (belt + suspenders — gitleaks is the
#      primary defense, this is the second line) ────────────────────
.env
.env.*
!.env.example
*.pem
*.key
*.p12
*.pfx
secrets/
credentials/

